# Secrets — NEVER commit these
.env
.env.local
.env.*.local

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.venv/
venv/
.pytest_cache/

# gbrain local DB (the markdown source-of-truth in brain/ IS tracked, the cached DB is not)
brain/.pglite/
brain/.gbrain-cache/

# Runtime state — machine-specific, never commit. Per-decision bet markdown
# (src/logging_setup.py), the kill/event logs, and the position ledger (which
# must NOT travel Mac→PC or the PC would think it holds positions the Mac
# recorded). Keep the directory itself via the tracked .gitkeep.
logs/*
!logs/.gitkeep

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Kalshi secrets - NEVER commit (RSA private key + key-bearing auth helper)
hermes_skills/**/*.pem
hermes_skills/**/kalshi_auth.py
