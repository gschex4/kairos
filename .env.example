# Kairos-only env vars. Copy to .env and fill in.
# NEVER commit .env — it holds your exchange credentials.
#
# IMPORTANT: vars that Hermes owns (XAI_API_KEY, TELEGRAM_BOT_TOKEN,
# TELEGRAM_CHAT_ID, GBRAIN_HOME) live in ~/.hermes/.env instead, not here.
# GBRAIN_HOME=~/.kairos isolates Kairos's brain from any other gbrain brain
# on the machine. See docs/HERMES_WIRING.md for the full split.

# --- Kalshi (required to place real bets) ---
# Kalshi is the live exchange. In your Kalshi account settings, create an API
# key — you get a key id plus an RSA private key (.pem). Put the key id in
# KALSHI_API_KEY and point KALSHI_KEY_PATH at the saved .pem file. Only needed
# in live mode; dry-run (KAIROS_DRY_RUN=true) loads without them. Leave blank
# until you go live so a missing value fails with a clear error.
KALSHI_API_KEY=
KALSHI_KEY_PATH=

# --- Polymarket (LEGACY — retired, not required) ---
# Kairos started on Polymarket, then migrated to Kalshi (Polymarket is
# US-restricted / view-only). Kept for back-compat only; leave blank.
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_CHAIN_ID=137

# --- Bankroll + sizing ---
# Original bankroll. Used to compute "% of starting bankroll remaining"
# for the milestone confidence floors.
KAIROS_STARTING_BANKROLL_USD=50

# Bankroll to assume in DRY_RUN, since the wallet isn't being read.
# Defaults to KAIROS_STARTING_BANKROLL_USD. Drop this to simulate the
# milestone floors triggering (e.g. set to 18 to test the 0.80 floor).
KAIROS_DRY_RUN_BANKROLL_USD=

# Paranoid absolute hard ceiling on a single bet (defense-in-depth on top
# of the 10% rule). Defaults to 20% of starting bankroll.
KAIROS_ABSOLUTE_MAX_BET_USD=

# When true, the bot reasons + logs but does NOT actually place bets.
# Flip to false only after a satisfying dry-run window.
KAIROS_DRY_RUN=true

# --- Paths (relative to project root, no need to change) ---
KAIROS_LOG_DIR=logs
KAIROS_BRAIN_DIR=brain

# --- Sports data feed backup (opt-in) ---
# ESPN's free undocumented API is the primary sports feed and needs no key.
# football-data.org is the backup oracle when ESPN's schema goes weird.
# Free signup: https://www.football-data.org/client/register
# 60s, 10 req/min, leave blank to skip.
KAIROS_FOOTBALL_DATA_KEY=
